<style>
:root{--font-display:'Georgia',serif;--font-body:-apple-system,'Segoe UI',sans-serif;--text-sm:.875rem;--text-base:1rem;--text-lg:1.125rem;--text-xl:1.25rem;--text-2xl:1.5rem;--radius-md:.75rem;--radius-lg:1.25rem;--radius-xl:2rem;--transition-interactive:200ms cubic-bezier(.4,0,.2,1)}
[data-theme="light"]{--color-bg:#f9f7f4;--color-bg-alt:#f0ede8;--color-bg-card:#ffffff;--color-text:#1a1714;--color-text-secondary:#5c574f;--color-text-tertiary:#8a8379;--color-primary:#2d7d6f;--color-primary-hover:#236358;--color-border:#ddd8d0;--shadow-md:0 4px 16px rgba(0,0,0,.08)}
[data-theme="dark"]{--color-bg:#141210;--color-bg-alt:#1e1b18;--color-bg-card:#242019;--color-text:#f0ede8;--color-text-secondary:#b5b0a7;--color-primary:#3d9e8e;--color-primary-hover:#4db8a6;--color-border:#2e2b27;--shadow-md:0 4px 16px rgba(0,0,0,.4)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{line-height:1.68;font-family:var(--font-body);font-size:var(--text-base);color:var(--color-text);background:var(--color-bg)}
a,button{transition:color var(--transition-interactive),background var(--transition-interactive),border-color var(--transition-interactive)}
a{text-decoration:none;color:inherit}
button{cursor:pointer;border:none;background:none}
h1,h2,h3{line-height:1.06}
p{max-width:70ch}
.site-header{position:sticky;top:0;z-index:50;background:color-mix(in oklab,var(--color-bg) 86%,transparent);backdrop-filter:blur(12px);border-bottom:1px solid var(--color-border);padding:.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem}
.site-logo{font-family:var(--font-display);font-size:var(--text-xl);font-weight:700}
.theme-toggle{width:2.25rem;height:2.25rem;border-radius:50%;display:flex;align-items:center;justify-content:center;background:var(--color-bg-alt);border:1px solid var(--color-border);color:var(--color-text-secondary)}
.hero-cta-btn{background:var(--color-primary);color:#fff;border-radius:9999px;padding:.6rem 1.5rem;font-size:var(--text-sm);font-weight:600}
.layout{max-width:1160px;margin:0 auto;padding:2rem 1.25rem;display:grid;grid-template-columns:1fr;gap:2.5rem}
@media(min-width:860px){.layout{grid-template-columns:1fr 320px;align-items:start}}
.article h1{font-family:var(--font-display);font-size:clamp(2rem,5vw,3.25rem);font-weight:700;margin-bottom:1.25rem}
.article h2{font-family:var(--font-display);font-size:clamp(1.4rem,3vw,2rem);font-weight:700;margin:2.5rem 0 1rem}
.article p{color:var(--color-text-secondary);font-size:var(--text-lg);margin-bottom:1.25rem}
.article strong{color:var(--color-text);font-weight:600}
.byline{font-size:var(--text-sm);color:var(--color-text-tertiary);margin-bottom:2rem;display:flex;gap:.5rem;flex-wrap:wrap}
.byline span{padding:.2rem .6rem;background:var(--color-bg-alt);border-radius:9999px}
.pull-quote{border-left:4px solid var(--color-primary);padding:1.25rem 1.5rem;margin:2rem 0;background:var(--color-bg-alt);border-radius:0 var(--radius-md) var(--radius-md) 0}
.pull-quote p{font-family:var(--font-display);font-size:var(--text-xl);font-style:italic;color:var(--color-text);margin:0}
.micro-steps{display:grid;gap:1rem;margin:1.5rem 0}
@media(min-width:600px){.micro-steps{grid-template-columns:repeat(3,1fr)}}
.step-card{background:var(--color-bg-card);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:1.25rem}
.step-card span{display:inline-flex;align-items:center;justify-content:center;width:2rem;height:2rem;background:var(--color-primary);color:#fff;border-radius:50%;font-size:var(--text-sm);font-weight:700;margin-bottom:.75rem}
.step-card h3{font-size:var(--text-base);font-weight:600;margin-bottom:.5rem}
.step-card p{font-size:var(--text-sm);color:var(--color-text-secondary);margin:0}
.review-grid{display:grid;gap:1rem;margin:1.5rem 0}
@media(min-width:600px){.review-grid{grid-template-columns:repeat(3,1fr)}}
.review-card{background:var(--color-bg-card);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:1.25rem}
.review-top{display:flex;justify-content:space-between;align-items:flex-start;gap:.5rem;margin-bottom:.75rem}
.review-top strong{font-size:var(--text-sm);font-weight:600;flex:1}
.stars{color:#f59e0b;font-size:var(--text-sm)}
.review-card p{font-size:var(--text-sm);color:var(--color-text-secondary);margin:0}
.sidebar{position:sticky;top:5rem;display:flex;flex-direction:column;gap:1.25rem}
.sidebar-card{background:var(--color-bg-card);border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:1.5rem;box-shadow:var(--shadow-md)}
.sidebar-card h3{font-size:var(--text-lg);font-weight:700;margin-bottom:.5rem}
.sidebar-card ul{list-style:none;display:flex;flex-direction:column;gap:.5rem;margin:.75rem 0 0}
.sidebar-card li{font-size:var(--text-sm);color:var(--color-text-secondary);padding-left:1.25rem;position:relative}
.sidebar-card li::before{content:'\2022';position:absolute;left:0;color:var(--color-primary)}
.btn{display:block;width:100%;padding:.875rem 1.5rem;border-radius:9999px;font-size:var(--text-sm);font-weight:600;text-align:center;cursor:pointer;border:none}
.btn-primary{background:var(--color-primary);color:#fff}.btn-primary:hover{background:var(--color-primary-hover)}
.btn-secondary{background:transparent;color:var(--color-text);border:1.5px solid var(--color-border)}.btn-secondary:hover{border-color:var(--color-primary);color:var(--color-primary)}
.cta-stack{display:flex;flex-direction:column;gap:.625rem}
.bottom-cta{background:var(--color-bg-alt);border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:2rem;margin-top:2rem}
.bottom-cta h2{font-family:var(--font-display);font-size:var(--text-2xl);margin-bottom:.75rem}
.quiz-step h3{font-size:var(--text-base);font-weight:600;margin-bottom:.5rem;color:var(--color-text-secondary)}
.quiz-step p{font-size:var(--text-lg);font-weight:600;color:var(--color-text);margin-bottom:1rem}
#quiz-result h3{font-family:var(--font-display);font-size:var(--text-2xl);font-weight:700;margin-bottom:.75rem}
#quiz-result p{font-size:var(--text-base);color:var(--color-text-secondary);margin-bottom:0}
</style>

<header class="site-header">
  <span class="site-logo">BackUp Buddy</span>
  <div style="display:flex;align-items:center;gap:.75rem;">
    <button class="theme-toggle" aria-label="Toggle theme" data-theme-toggle>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
    <button class="hero-cta-btn" type="button" data-open-quiz>Start fit quiz</button>
  </div>
</header>

<main id="main">
  <div class="layout">
    <article class="article">
      <h1>The dog that stopped walking &mdash; and the harness that helped him start again</h1>
      <div class="byline"><span>Senior Dog Care</span><span>Mobility Support</span><span>5 min read</span></div>
      <p>My neighbour's golden retriever, Bear, used to meet me at the gate every morning. Tail going, eyes bright, that low woof he saved for people he liked. Then one autumn he just&hellip; didn't come anymore.</p>
      <p>She told me his back legs had started going. Not dramatically &mdash; no single moment, just a slow drift. He'd slip on the kitchen tiles. He'd hesitate at the bottom of the stairs. The vet said it was age-related muscle weakness, common in large breeds past eight or nine.</p>
      <p><strong>&ldquo;I felt like I was watching him disappear,&rdquo;</strong> she said. &ldquo;Not all at once. Just a little more each week.&rdquo;</p>
      <div class="pull-quote"><p>&ldquo;I didn&rsquo;t want to carry him. I wanted to help him carry himself.&rdquo;</p></div>
      <h2>What rear-leg support actually does</h2>
      <p>Most owners dealing with this face the same choice: limit the dog&rsquo;s activity, or find a way to support them through it. Rear-lift harnesses exist specifically for this &mdash; they let you provide lift under the hindquarters without taking over the dog&rsquo;s movement.</p>
      <p>A good one stays on during a walk, handles a curb, and doesn&rsquo;t need to come off every time the dog sits down. Simple enough that you&rsquo;d actually use it every day.</p>
      <h2>The BackUp Buddy</h2>
      <p>BackUp Buddy is a rear-support harness for dogs with weak or recovering hind legs. It wraps the hindquarters with a padded lifting section and two sturdy handles, so you can give support from above without straining your back.</p>
      <p>Fits dogs from small to large. Made for full-day wear, not just short sessions.</p>
      <div class="micro-steps">
        <article class="step-card"><span>1</span><h3>Wrap and clip</h3><p>Fits over the hindquarters and clips at the belly &mdash; no stepping in required.</p></article>
        <article class="step-card"><span>2</span><h3>Lift from above</h3><p>Padded handles let you guide the dog upright without straining your back.</p></article>
        <article class="step-card"><span>3</span><h3>Carry on</h3><p>Designed for full-day wear so it stays on through walks, trips, and daily routines.</p></article>
      </div>
      <h2 id="reviews">What people actually say</h2>
      <div class="review-grid">
        <article class="review-card"><div class="review-top"><strong>&ldquo;Really sturdy, even for dogs that pull.&rdquo;</strong><span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div><p>Felt strong and held up well. The sizing came out right after following the chart.</p></article>
        <article class="review-card"><div class="review-top"><strong>&ldquo;The right size and very comfortable.&rdquo;</strong><span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div><p>Fit was correct, comfortable, and easier to use than others because the dog didn&rsquo;t need to step into it.</p></article>
        <article class="review-card"><div class="review-top"><strong>&ldquo;Very practical for everyday walks.&rdquo;</strong><span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div><p>Easy to put on and suitable for everyday use all year round.</p></article>
      </div>
      <h2>What normal looks like now</h2>
      <p>Bear is back at the gate most mornings. His owner lifts him over the doorstep, clips the harness, and they do a slow loop around the block.</p>
      <p><strong>&ldquo;Normal changed.&rdquo;</strong> she told me. <strong>&ldquo;But there&rsquo;s still a normal. That&rsquo;s the part I didn&rsquo;t expect.&rdquo;</strong></p>
      <p>If this sounds like your dog, the fit quiz will match you to the right size in about a minute.</p>
      <section id="fit-quiz" class="bottom-cta" hidden aria-hidden="true">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;">
          <div><h2>Quick fit quiz</h2><p style="margin:0;color:var(--color-text-secondary);">3 questions. We&rsquo;ll match the right size for your dog.</p></div>
          <button class="theme-toggle" type="button" data-close-quiz style="flex-shrink:0;">&#x2715;</button>
        </div>
        <div style="margin:1rem 0 1.25rem;background:color-mix(in oklab,var(--color-text) 8%,transparent);height:8px;border-radius:9999px;overflow:hidden;">
          <div id="quiz-progress" style="width:33%;height:100%;background:var(--color-primary);border-radius:9999px;transition:width .25s ease;"></div>
        </div>
        <div id="quiz-step-1" class="quiz-step">
          <h3>Question 1 of 3</h3><p>How big is your dog?</p>
          <div class="cta-stack" style="max-width:520px;">
            <button class="btn btn-secondary quiz-choice" data-next-step="2">Small / under 25 lbs</button>
            <button class="btn btn-secondary quiz-choice" data-next-step="2">Medium / 25&ndash;50 lbs</button>
            <button class="btn btn-secondary quiz-choice" data-next-step="2">Large / 50+ lbs</button>
          </div>
        </div>
        <div id="quiz-step-2" class="quiz-step" hidden>
          <h3>Question 2 of 3</h3><p>What&rsquo;s the main struggle right now?</p>
          <div class="cta-stack" style="max-width:520px;">
            <button class="btn btn-secondary quiz-choice" data-next-step="3">Stairs</button>
            <button class="btn btn-secondary quiz-choice" data-next-step="3">Car rides</button>
            <button class="btn btn-secondary quiz-choice" data-next-step="3">Standing up / walking</button>
          </div>
        </div>
        <div id="quiz-step-3" class="quiz-step" hidden>
          <h3>Question 3 of 3</h3><p>How much support do they need most days?</p>
          <div class="cta-stack" style="max-width:520px;">
            <button class="btn btn-secondary quiz-choice" data-show-result="true">Light support</button>
            <button class="btn btn-secondary quiz-choice" data-show-result="true">Moderate support</button>
            <button class="btn btn-secondary quiz-choice" data-show-result="true">Heavy rear-leg help</button>
          </div>
        </div>
        <div id="quiz-result" hidden>
          <h3>We found the perfect size for you</h3>
          <p>Your dog looks like a strong fit for BackUp Buddy. Choose your colour next, then continue to checkout.</p>
          <div class="cta-stack" style="margin-top:1.25rem;max-width:360px;">
            <a class="btn btn-primary" href="/products/backup-buddy">Pick colour &amp; checkout</a>
            <a class="btn btn-secondary" href="#reviews">Read reviews first</a>
          </div>
        </div>
      </section>
      <section id="checkout" class="bottom-cta">
        <h2>Ready when you are</h2>
        <p>Take the fit quiz and we&rsquo;ll confirm the right size, then head straight to checkout.</p>
        <div class="cta-stack" style="margin-top:1rem;max-width:340px;">
          <button class="btn btn-primary" type="button" data-open-quiz>Take the fit quiz</button>
          <a class="btn btn-secondary" href="#reviews">Read reviews first</a>
        </div>
      </section>
    </article>
    <aside class="sidebar">
      <div class="sidebar-card">
        <h3>BackUp Buddy</h3>
        <p style="font-size:var(--text-sm);color:var(--color-text-secondary);margin:.25rem 0 0;">A rear-lift mobility harness for senior and mobility-impaired dogs.</p>
        <ul>
          <li>Supports weak back legs without awkward lifting</li>
          <li>Helps preserve walks, park trips, and daily routines</li>
          <li>Padded handles for steadier support</li>
          <li>Designed to stay practical for everyday use</li>
        </ul>
      </div>
      <div class="sidebar-card cta-stack">
        <button class="btn btn-primary" type="button" data-open-quiz>Take fit quiz</button>
        <a class="btn btn-secondary" href="#reviews">Read reviews</a>
        <a class="btn btn-secondary" href="/products/backup-buddy">Continue to checkout</a>
      </div>
    </aside>
  </div>
</main>

<script>
(function(){
  const toggle=document.querySelector('[data-theme-toggle]');
  const root=document.documentElement;
  let theme=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';
  root.setAttribute('data-theme',theme);
  const render=()=>{if(toggle)toggle.innerHTML=theme==='dark'?'<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>':'<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';};
  render();
  if(toggle)toggle.addEventListener('click',()=>{theme=theme==='dark'?'light':'dark';root.setAttribute('data-theme',theme);render();});
  const quiz=document.querySelector('#fit-quiz');
  const steps=[document.querySelector('#quiz-step-1'),document.querySelector('#quiz-step-2'),document.querySelector('#quiz-step-3')];
  const result=document.querySelector('#quiz-result');
  const progress=document.querySelector('#quiz-progress');
  const showStep=(n)=>{steps.forEach((el,i)=>{if(el)el.hidden=(i+1)!==n;});if(result)result.hidden=true;if(progress)progress.style.width=(n===1?33:n===2?66:100)+'%';};
  const openQuiz=()=>{if(!quiz)return;quiz.hidden=false;quiz.setAttribute('aria-hidden','false');showStep(1);quiz.scrollIntoView({behavior:'smooth',block:'center'});};
  const closeQuiz=()=>{if(!quiz)return;quiz.hidden=true;quiz.setAttribute('aria-hidden','true');};
  document.querySelectorAll('[data-open-quiz]').forEach(b=>b.addEventListener('click',openQuiz));
  document.querySelectorAll('[data-close-quiz]').forEach(b=>b.addEventListener('click',closeQuiz));
  document.addEventListener('keydown',e=>{if(e.key==='Escape')closeQuiz();});
  document.querySelectorAll('.quiz-choice').forEach(btn=>btn.addEventListener('click',()=>{
    const next=btn.getAttribute('data-next-step');
    const showRes=btn.getAttribute('data-show-result');
    if(showRes==='true'){steps.forEach(el=>{if(el)el.hidden=true;});if(result)result.hidden=false;if(progress)progress.style.width='100%';return;}
    if(next)showStep(parseInt(next,10));
  }));
})();
</script>

